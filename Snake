<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🐍 코브라 게임</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', 'Malgun Gothic', sans-serif;
    background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    padding: 20px;
  }
  .container {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(10px);
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }
  h1 {
    font-size: 2.2em;
    margin-bottom: 10px;
    background: linear-gradient(90deg, #56ab2f, #a8e063);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    font-size: 1.1em;
  }
  .score, .high-score {
    background: rgba(255, 255, 255, 0.1);
    padding: 8px 16px;
    border-radius: 10px;
    font-weight: bold;
  }
  .score span, .high-score span { color: #a8e063; }
  canvas {
    background: #0a1a2f;
    border: 3px solid rgba(168, 224, 99, 0.4);
    border-radius: 12px;
    display: block;
    box-shadow: 0 0 30px rgba(168, 224, 99, 0.2) inset;
  }
  .controls {
    margin-top: 15px;
    font-size: 0.9em;
    opacity: 0.75;
    line-height: 1.6;
  }
  .controls kbd {
    background: rgba(255, 255, 255, 0.15);
    padding: 2px 8px;
    border-radius: 5px;
    font-family: monospace;
    margin: 0 2px;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .overlay.show { opacity: 1; pointer-events: auto; }
  .overlay h2 {
    font-size: 2.5em;
    margin-bottom: 10px;
    color: #ff6b6b;
  }
  .overlay p { margin-bottom: 20px; font-size: 1.1em; }
  .btn {
    background: linear-gradient(90deg, #56ab2f, #a8e063);
    color: #0a1a2f;
    border: none;
    padding: 12px 30px;
    font-size: 1em;
    font-weight: bold;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(168, 224, 99, 0.4); }
  .game-wrapper { position: relative; display: inline-block; }
  /* 모바일 방향 버튼 */
  .dpad {
    display: none;
    margin-top: 20px;
    grid-template-columns: repeat(3, 60px);
    grid-template-rows: repeat(3, 60px);
    gap: 5px;
    justify-content: center;
  }
  .dpad button {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1.5em;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .dpad button:active { background: rgba(168, 224, 99, 0.4); }
  .dpad .up { grid-column: 2; grid-row: 1; }
  .dpad .left { grid-column: 1; grid-row: 2; }
  .dpad .right { grid-column: 3; grid-row: 2; }
  .dpad .down { grid-column: 2; grid-row: 3; }
  @media (max-width: 600px) {
    .dpad { display: grid; }
    h1 { font-size: 1.6em; }
  }
</style>
</head>
<body>
  <div class="container">
    <h1>🐍 코브라 게임</h1>
    <div class="info">
      <div class="score">점수: <span id="score">0</span></div>
      <div class="high-score">최고: <span id="highScore">0</span></div>
    </div>
    <div class="game-wrapper">
      <canvas id="game" width="400" height="400"></canvas>
      <div class="overlay" id="overlay">
        <h2 id="overlayTitle">게임 오버</h2>
        <p id="overlayMsg">점수: 0</p>
        <button class="btn" id="restartBtn">다시 시작</button>
      </div>
    </div>
    <div class="controls">
      <kbd>↑</kbd><kbd>↓</kbd><kbd>←</kbd><kbd>→</kbd> 또는 <kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> 로 조작<br>
      <kbd>Space</kbd> 일시정지 · <kbd>R</kbd> 재시작
    </div>
    <div class="dpad">
      <button class="up" data-dir="up">▲</button>
      <button class="left" data-dir="left">◀</button>
      <button class="right" data-dir="right">▶</button>
      <button class="down" data-dir="down">▼</button>
    </div>
  </div>

<script>
  const canvas = document.getElementById('game');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const highScoreEl = document.getElementById('highScore');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlayTitle');
  const overlayMsg = document.getElementById('overlayMsg');
  const restartBtn = document.getElementById('restartBtn');

  const GRID = 20;              // 한 칸 크기 (px)
  const COLS = canvas.width / GRID;
  const ROWS = canvas.height / GRID;

  let snake, dir, nextDir, food, score, highScore, speed, gameOver, paused, lastTick;

  // 세션 내 최고점 (Claude 아티팩트는 localStorage 미지원)
  highScore = 0;

  function init() {
    snake = [
      { x: 10, y: 10 },
      { x: 9, y: 10 },
      { x: 8, y: 10 }
    ];
    dir = { x: 1, y: 0 };
    nextDir = { x: 1, y: 0 };
    score = 0;
    speed = 130;   // ms per step
    gameOver = false;
    paused = false;
    lastTick = 0;
    placeFood();
    updateScore();
    overlay.classList.remove('show');
  }

  function placeFood() {
    while (true) {
      const f = {
        x: Math.floor(Math.random() * COLS),
        y: Math.floor(Math.random() * ROWS)
      };
      if (!snake.some(s => s.x === f.x && s.y === f.y)) {
        food = f;
        return;
      }
    }
  }

  function updateScore() {
    scoreEl.textContent = score;
    highScoreEl.textContent = highScore;
  }

  function step() {
    // 방향 적용 (반대 방향으로는 못 감)
    if (nextDir.x !== -dir.x || nextDir.y !== -dir.y) {
      dir = nextDir;
    }
    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };

    // 벽 충돌
    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {
      return endGame();
    }
    // 자기 몸 충돌
    if (snake.some(s => s.x === head.x && s.y === head.y)) {
      return endGame();
    }

    snake.unshift(head);

    // 먹이 획득
    if (head.x === food.x && head.y === food.y) {
      score += 10;
      if (score > highScore) highScore = score;
      updateScore();
      if (speed > 60) speed -= 2; // 점점 빨라짐
      placeFood();
    } else {
      snake.pop();
    }
  }

  function draw() {
    // 배경 그리드
    ctx.fillStyle = '#0a1a2f';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.strokeStyle = 'rgba(255,255,255,0.03)';
    for (let i = 0; i <= COLS; i++) {
      ctx.beginPath();
      ctx.moveTo(i * GRID, 0);
      ctx.lineTo(i * GRID, canvas.height);
      ctx.stroke();
    }
    for (let i = 0; i <= ROWS; i++) {
      ctx.beginPath();
      ctx.moveTo(0, i * GRID);
      ctx.lineTo(canvas.width, i * GRID);
      ctx.stroke();
    }

    // 먹이 (반짝임 효과)
    const pulse = 0.6 + 0.4 * Math.sin(Date.now() / 200);
    ctx.fillStyle = `rgba(255, 107, 107, ${pulse})`;
    ctx.shadowColor = '#ff6b6b';
    ctx.shadowBlur = 15;
    ctx.beginPath();
    ctx.arc(
      food.x * GRID + GRID / 2,
      food.y * GRID + GRID / 2,
      GRID / 2 - 2,
      0, Math.PI * 2
    );
    ctx.fill();
    ctx.shadowBlur = 0;

    // 뱀
    snake.forEach((seg, i) => {
      const isHead = i === 0;
      const g = 1 - i / (snake.length * 1.5);
      ctx.fillStyle = isHead
        ? '#a8e063'
        : `rgba(86, 171, 47, ${0.5 + g * 0.5})`;
      const pad = isHead ? 1 : 2;
      ctx.fillRect(
        seg.x * GRID + pad,
        seg.y * GRID + pad,
        GRID - pad * 2,
        GRID - pad * 2
      );
      // 머리 눈
      if (isHead) {
        ctx.fillStyle = '#0a1a2f';
        const eyeSize = 3;
        const cx = seg.x * GRID + GRID / 2;
        const cy = seg.y * GRID + GRID / 2;
        const offX = dir.x * 4;
        const offY = dir.y * 4;
        const perpX = -dir.y * 4;
        const perpY = dir.x * 4;
        ctx.fillRect(cx + offX + perpX - eyeSize / 2, cy + offY + perpY - eyeSize / 2, eyeSize, eyeSize);
        ctx.fillRect(cx + offX - perpX - eyeSize / 2, cy + offY - perpY - eyeSize / 2, eyeSize, eyeSize);
      }
    });

    // 일시정지 표시
    if (paused && !gameOver) {
      ctx.fillStyle = 'rgba(0,0,0,0.5)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 32px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('일시정지', canvas.width / 2, canvas.height / 2);
    }
  }

  function endGame() {
    gameOver = true;
    overlayTitle.textContent = '게임 오버';
    overlayMsg.textContent = `점수: ${score}  ·  최고: ${highScore}`;
    overlay.classList.add('show');
  }

  function loop(ts) {
    if (!gameOver && !paused) {
      if (ts - lastTick > speed) {
        step();
        lastTick = ts;
      }
    }
    draw();
    requestAnimationFrame(loop);
  }

  // 키보드 조작
  const keyMap = {
    ArrowUp: [0, -1], ArrowDown: [0, 1], ArrowLeft: [-1, 0], ArrowRight: [1, 0],
    w: [0, -1], s: [0, 1], a: [-1, 0], d: [1, 0],
    W: [0, -1], S: [0, 1], A: [-1, 0], D: [1, 0]
  };
  document.addEventListener('keydown', e => {
    if (keyMap[e.key]) {
      e.preventDefault();
      const [x, y] = keyMap[e.key];
      nextDir = { x, y };
    } else if (e.key === ' ') {
      e.preventDefault();
      if (!gameOver) paused = !paused;
    } else if (e.key === 'r' || e.key === 'R') {
      init();
    }
  });

  // 재시작 버튼
  restartBtn.addEventListener('click', init);

  // 모바일 D-pad
  document.querySelectorAll('.dpad button').forEach(btn => {
    btn.addEventListener('click', () => {
      const d = btn.dataset.dir;
      if (d === 'up') nextDir = { x: 0, y: -1 };
      if (d === 'down') nextDir = { x: 0, y: 1 };
      if (d === 'left') nextDir = { x: -1, y: 0 };
      if (d === 'right') nextDir = { x: 1, y: 0 };
    });
  });

  // 스와이프 지원
  let touchStart = null;
  canvas.addEventListener('touchstart', e => {
    touchStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
  });
  canvas.addEventListener('touchend', e => {
    if (!touchStart) return;
    const dx = e.changedTouches[0].clientX - touchStart.x;
    const dy = e.changedTouches[0].clientY - touchStart.y;
    if (Math.abs(dx) > Math.abs(dy)) {
      nextDir = dx > 0 ? { x: 1, y: 0 } : { x: -1, y: 0 };
    } else {
      nextDir = dy > 0 ? { x: 0, y: 1 } : { x: 0, y: -1 };
    }
    touchStart = null;
  });

  init();
  requestAnimationFrame(loop);
</script>
</body>
</html>
